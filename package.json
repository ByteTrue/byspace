{
  "name": "byspace",
  "version": "0.1.1",
  "private": true,
  "description": "Web and CLI control plane for local AI coding agents",
  "keywords": [
    "development",
    "mcp",
    "openai",
    "voice",
    "voice-assistant"
  ],
  "homepage": "https://byspace.pages.dev",
  "license": "AGPL-3.0-or-later",
  "author": {
    "name": "ByteTrue"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ByteTrue/byspace.git"
  },
  "workspaces": [
    "packages/highlight",
    "packages/protocol",
    "packages/client",
    "packages/server",
    "packages/app",
    "packages/relay",
    "packages/cli"
  ],
  "scripts": {
    "dev": "npm run dev:server",
    "dev:win": "powershell ./scripts/dev.ps1",
    "dev:server": "cross-env BYSPACE_LISTEN=127.0.0.1:6768 ./scripts/dev-daemon.sh",
    "dev:server:watch": "concurrently --kill-others --names protocol,client,server --prefix-colors yellow,blue,cyan \"npm run watch:protocol\" \"npm run watch:client\" \"npm run dev:server:raw\"",
    "dev:server:raw": "npm run dev --workspace=@bytetrue/byspace-server",
    "dev:app": "cross-env BYSPACE_LISTEN=127.0.0.1:6768 EXPO_PORT=8081 ./scripts/dev-app.sh",
    "postinstall": "node scripts/postinstall-patches.mjs",
    "prepare": "lefthook install --force",
    "upstream:check": "node scripts/check-upstream-sync-state.mjs",
    "branding:check": "node scripts/check-branding.mjs",
    "build": "npm run build --workspaces --if-present",
    "build:highlight": "npm run build --workspace=@bytetrue/byspace-highlight",
    "build:highlight:clean": "npm run build:clean --workspace=@bytetrue/byspace-highlight",
    "build:relay": "npm run build --workspace=@bytetrue/byspace-relay",
    "build:relay:clean": "npm run build:clean --workspace=@bytetrue/byspace-relay",
    "build:protocol": "npm run build --workspace=@bytetrue/byspace-protocol",
    "build:protocol:clean": "npm run build:clean --workspace=@bytetrue/byspace-protocol",
    "build:client": "npm run build:protocol && npm run build --workspace=@bytetrue/byspace-client",
    "build:client:clean": "npm run build:protocol:clean && npm run build:clean --workspace=@bytetrue/byspace-client",
    "build:server-deps": "npm run build:highlight && npm run build:relay && npm run build:client",
    "build:server-deps:clean": "npm run build:highlight:clean && npm run build:relay:clean && npm run build:client:clean",
    "build:server": "npm run build:server-deps && npm run build --workspace=@bytetrue/byspace-server && npm run build --workspace=@bytetrue/byspace",
    "build:server:clean": "npm run build:server-deps:clean && npm run build:clean --workspace=@bytetrue/byspace-server && npm run build:clean --workspace=@bytetrue/byspace",
    "build:daemon-web-ui": "node scripts/build-daemon-web-ui.mjs",
    "pack:byspace": "node scripts/pack-byspace.mjs",
    "test:pack": "node --test scripts/pack-byspace-output.test.mjs",
    "smoke:package": "node scripts/smoke-byspace-package.mjs",
    "build:app-deps": "npm run build:highlight && npm run build:client",
    "build:app-deps:clean": "npm run build:highlight:clean && npm run build:client:clean",
    "watch:protocol": "npm run watch --workspace=@bytetrue/byspace-protocol",
    "watch:client": "tsc -p packages/client/tsconfig.json --watch --preserveWatchOutput",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "typecheck:server": "npm run typecheck --workspace=@bytetrue/byspace-relay && npm run typecheck --workspace=@bytetrue/byspace-protocol && npm run typecheck --workspace=@bytetrue/byspace-client && npm run typecheck --workspace=@bytetrue/byspace-server && npm run typecheck --workspace=@bytetrue/byspace",
    "test": "npm run test --workspaces --if-present",
    "format": "oxfmt .",
    "format:files": "oxfmt",
    "format:check": "oxfmt --check .",
    "format:check:files": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "knip": "knip",
    "acp:version-drift": "node scripts/check-acp-catalog-version-drift.mjs",
    "acp:version-drift:check": "node scripts/check-acp-catalog-version-drift.mjs --fail-on-drift",
    "acp:version-drift:update": "node scripts/check-acp-catalog-version-drift.mjs --update",
    "start": "npm run start --workspace=@bytetrue/byspace-server",
    "web": "npm run web --workspace=@bytetrue/byspace-app",
    "db:query": "npm run db:query --workspace=@bytetrue/byspace-server --",
    "cli": "./scripts/dev-home.sh npx tsx packages/cli/src/index.js",
    "version": "npm run version:sync-internal && npm run release:prepare && git add -A",
    "version:sync-internal": "node scripts/sync-workspace-versions.mjs",
    "release:prepare": "npm install --workspaces --include-workspace-root",
    "version:all:patch": "node scripts/set-release-version.mjs --mode patch",
    "version:all:minor": "node scripts/set-release-version.mjs --mode minor",
    "version:all:major": "node scripts/set-release-version.mjs --mode major",
    "version:all:beta:patch": "node scripts/set-release-version.mjs --mode beta-patch",
    "version:all:beta:minor": "node scripts/set-release-version.mjs --mode beta-minor",
    "version:all:beta:major": "node scripts/set-release-version.mjs --mode beta-major",
    "version:all:beta:next": "node scripts/set-release-version.mjs --mode beta-next",
    "version:all:promote": "node scripts/set-release-version.mjs --mode promote",
    "release:check": "npm run branding:check && npm run upstream:check && npm run release:prepare && npm run test:pack && npm run typecheck && npm run lint && npm run format:check && npm run smoke:package && npm run release:verify",
    "release:verify": "node scripts/publish-byspace.mjs --dry-run --skip-pack",
    "release:publish:dry-run": "node scripts/publish-byspace.mjs --dry-run",
    "release:publish:beta:dry-run": "node scripts/publish-byspace.mjs --dry-run --tag beta",
    "release:publish": "node scripts/publish-byspace.mjs --skip-pack",
    "release:publish:beta": "node scripts/publish-byspace.mjs --skip-pack --tag beta"
  },
  "devDependencies": {
    "@types/ws": "^8.5.14",
    "@typescript/native-preview": "7.0.0-dev.20260423.1",
    "@vercel/nft": "^1.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "get-port-cli": "^3.0.0",
    "js-yaml": "^4.1.1",
    "knip": "^5.82.1",
    "lefthook": "^2.1.6",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "oxlint-tsgolint": "^0.22.1",
    "patch-package": "^8.0.1",
    "playwright": "^1.56.1",
    "typescript": "^5.9.3",
    "ws": "^8.20.0"
  },
  "overrides": {
    "lightningcss": "1.30.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native-reanimated": "4.3.1",
    "react-native-worklets": "0.8.3"
  }
}
