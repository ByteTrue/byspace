{
  "name": "@bytetrue/byspace",
  "version": "0.1.0",
  "description": "Web and CLI control plane for local AI coding agents",
  "keywords": [
    "agents",
    "ai",
    "cli",
    "daemon",
    "web"
  ],
  "homepage": "https://byspace.pages.dev",
  "bugs": {
    "url": "https://github.com/ByteTrue/byspace/issues"
  },
  "license": "AGPL-3.0-or-later",
  "author": {
    "name": "ByteTrue"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ByteTrue/byspace.git"
  },
  "bin": {
    "byspace": "bin/byspace"
  },
  "files": [
    "bin",
    "dist",
    "!dist/**/*.map"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node ../../scripts/clean-package-dist.mjs",
    "build": "tsc -p tsconfig.json --incremental false",
    "build:clean": "npm run clean && npm run build",
    "prepack": "npm run build:clean",
    "typecheck": "tsgo --noEmit",
    "test": "npm run test:local",
    "test:local": "tsx tests/run-all.ts",
    "test:e2e": "npm run test:local",
    "test:e2e:lifecycle": "npx tsx tests/e2e/agent-lifecycle.test.ts"
  },
  "dependencies": {
    "@bytetrue/byspace-client": "0.1.0",
    "@bytetrue/byspace-protocol": "0.1.0",
    "@bytetrue/byspace-server": "0.1.0",
    "@clack/prompts": "^1.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "mime-types": "^2.1.35",
    "tree-kill": "^1.2.2",
    "ws": "^8.14.2",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/ws": "^8.5.8",
    "tsx": "^4.6.0",
    "typescript": "^5.2.2",
    "vitest": "^4.1.6",
    "zx": "^8.8.5"
  },
  "engines": {
    "node": ">=22"
  }
}
