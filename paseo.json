{
  "worktree": {
    "setup": [
      "npm ci",
      "BYSPACE_DEV_MANAGED_HOME=1 BYSPACE_DEV_SEED_HOME=\"$BYSPACE_SOURCE_CHECKOUT_PATH/.dev/paseo-home\" BYSPACE_HOME=\"$PWD/.dev/paseo-home\" ./scripts/dev-home.sh",
      "npm run build:server",
      "cp \"$BYSPACE_SOURCE_CHECKOUT_PATH/packages/server/.env\" \"$PWD/packages/server/.env\""
    ]
  },
  "scripts": {
    "daemon": {
      "type": "service",
      "command": "BYSPACE_DEV_MANAGED_HOME=1 BYSPACE_DEV_ROOT=\"${BYSPACE_WORKTREE_PATH:-$PWD}\" BYSPACE_HOME=\"${BYSPACE_WORKTREE_PATH:-$PWD}/.dev/paseo-home\" BYSPACE_SKIP_DEV_SERVER_BUILD=1 BYSPACE_LISTEN=0.0.0.0:${BYSPACE_PORT:-6768} ./scripts/dev-daemon.sh"
    },
    "app": {
      "type": "service",
      "command": "BYSPACE_DEV_MANAGED_HOME=1 BYSPACE_DEV_ROOT=\"${BYSPACE_WORKTREE_PATH:-$PWD}\" BYSPACE_HOME=\"${BYSPACE_WORKTREE_PATH:-$PWD}/.dev/paseo-home\" BYSPACE_LISTEN=0.0.0.0:${BYSPACE_SERVICE_DAEMON_PORT:-6768} BYSPACE_DEV_DAEMON_ENDPOINT=localhost:${BYSPACE_SERVICE_DAEMON_PORT:-6768} EXPO_PORT=${BYSPACE_PORT:-} ./scripts/dev-app.sh"
    },
    "typecheck": {
      "command": "npm run typecheck"
    }
  }
}
