# Example child image that adds agent CLIs to the locally built BySpace image.
#
# First build the base image from the repository root:
#   docker build -f docker/base/Dockerfile -t byspace:local .
#
# Then build this child image:
#   docker build -f docker/Dockerfile.agents.example -t byspace-with-agents .
#
# Set `image: byspace-with-agents` in your Compose file to use it.

FROM byspace:local

USER root
RUN npm install -g \
  @anthropic-ai/claude-code \
  @openai/codex \
  opencode-ai

# Leave the image user as root. The base entrypoint prepares mounted volumes,
# then drops the daemon and launched agents to the non-root `byspace` user.
